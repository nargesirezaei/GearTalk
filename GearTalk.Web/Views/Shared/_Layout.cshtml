@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> signInManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GearTalk.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GearTalk.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link href='https://cdn.jsdelivr.net/npm/froala-editor@latest/css/froala_editor.pkgd.min.css' rel='stylesheet' type='text/css' />
    <script type='text/javascript' src='https://cdn.jsdelivr.net/npm/froala-editor@latest/js/froala_editor.pkgd.min.js'></script>
</head>
<body>
    <header class="header">
        <nav class="navbar navbar-expand-sm navbar-dark  bg-dark border-bottom box-shadow ">
            <div class="container">
            
               @*  <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">GearTalk</a> *@
                <a class="navbar-brand d-flex align-items-center"
                       asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/gearTalk.png" class="nav-logo me-2" alt="GearTalk logo" />
                    @* <span>GearTalk</span> *@
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Index">Reviews</a>
                        </li>
                        @if (signInManager.IsSignedIn(User)&& User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Admin
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="AdminCarCategories" asp-action="Add">Add New Category</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="AdminCarCategories" asp-action="List">All Category</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="AdminCarReview" asp-action="Add">Add New Car Review</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="AdminCarReview" asp-action="List">All Car Reviewes</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="AdminUsers" asp-action="List">All Users</a></li>

                                </ul>
                            </li>
                        }


                        

                    </ul>
                    
                    <div class="d-flex align-items-center">

                        @if (signInManager.IsSignedIn(User))
                        {
                            <div class="me-3 text-light">
                                @User?.Identity?.Name
                            </div>
                            <a class="btn me-3 bg-light text-dark " asp-area="" asp-controller="Account" asp-action="LogOut">
                                Log out
                            </a>
                        }else
                        {
                            <a class="btn btn-light me-3"
                               asp-controller="Account"
                               asp-action="Register">
                                Register
                            </a>

                            <a class="btn btn-light me-3"
                               asp-controller="Account"
                               asp-action="Login">
                                Login
                            </a>
                        }
                        

                    </div>

                    
                       

                    
            </div>
        </nav>
    </header>
   
            <main role="main" class="pb-3 flex-grow-1">
            @RenderBody()
        </main>
    
        <footer class="site-footer bg-dark text-light pt-4 pb-3 mt-7">
            <div class="container">

                <!-- Top row: Socials (left) + Region (right) -->
                <div class="row align-items-center mb-3">

                    <!-- Social icons -->
                    <div class="col-12 col-md-6 mb-3 mb-md-0">
                        <div class="d-flex gap-3">

                            <a href="https://www.instagram.com/mrmehdi7i/?utm_source=ig_web_button_share_sheet" class="text-light fs-4">
                                <i class="bi bi-instagram"></i>
                            </a>

                            <a href="https://www.youtube.com/channel/UCKMzbyQERTZSqbt1Ci3SL9w"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   class="text-light fs-4">
                                <i class="bi bi-youtube"></i>
                            </a>

                            <a href="https://www.tiktok.com/@@mrmehdis7"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   class="text-light fs-4">
                                <i class="bi bi-tiktok"></i>
                            </a>

                            <a href="https://www.facebook.com/mehdi.su" class="text-light fs-4">
                                <i class="bi bi-facebook"></i>
                            </a>

                        </div>
                    </div>

                    <!-- Region selector -->
                    <div class="col-12 col-md-6 text-md-end">
                        <select class="form-select w-auto d-inline-block bg-dark text-light border-secondary">
                            <option selected>Region: Norway</option>
                            <option>Europe</option>
                            <option>USA</option>
                            <option>Asia</option>
                        </select>
                    </div>

                </div>

                <!-- Divider line -->
                <hr class="border-secondary" />

                <!-- Bottom row: links -->
                <div class="d-flex justify-content-between small">
                    @* <a asp-controller="Home" asp-action="ContactUs" class="text-light text-decoration-none">Contact Us</a> *@
                    <a asp-controller="Home" asp-action="Privacy" class="text-light text-decoration-none">Privacy Policy</a>
                </div>

            </div>
        </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
