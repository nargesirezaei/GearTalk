@model GearTalk.Web.Models.ViewModel.EditCarCategoryRequest

<div class=" bg-secondary bg-opacity-10 py-2">
    <div class="container">
        <h1>Edit Car Category - Admin Functionallity</h1>
    </div>
</div>

<div class="container py-5 ">
@if(Model != null )
{
    
        <form method="post">

            <div class="mb-3">
                <label class="form-label">Id</label>
                <input type="text" class="form-control" asp-for="Id" id="Id" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" class="form-control" asp-for="Name" id="name" />
            </div>

            <div class="mb-3">
                <label class="form-label">DisplayName</label>
                <input type="text" class="form-control" asp-for="DisplayName" id="displayName" />
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-dark">Update</button>

            </div>
    
        </form>
    }else
    {
        <p>Tag not found!</p>
    }
</div>



